# PDB Tracker — Environment Configuration
# Copy to ~/.pdb-tracker/.env  (or any location via PDB_DATA_DIR)
# All variables are optional; defaults are shown in comments below.

# ── Data directories ──────────────────────────────────────────────────────────
# Top-level data directory (default: ~/.pdb-tracker/)
# PDB_DATA_DIR=/custom/path

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite database file name (default: pdb_tracker.db)
# PDB_DB_NAME=pdb_tracker.db

# ── Weekly reports ─────────────────────────────────────────────────────────────
# Weekly report .md files directory (default: ~/.pdb-tracker/weekly_reports/)
# PDB_WEEKLY_DIR=/path/to/weekly_reports

# ── Target evaluations ─────────────────────────────────────────────────────────
# Evaluation JSON + .md report directory (default: ~/.pdb-tracker/evaluations/)
# PDB_EVAL_DIR=/path/to/evaluations

# ── Web UI ────────────────────────────────────────────────────────────────────
# Host to bind (default: 0.0.0.0 — change to 127.0.0.1 for local-only)
# PDB_WEB_HOST=0.0.0.0

# Port for the web UI (default: 5555)
# PDB_WEB_PORT=5555

# Enable Flask debug mode (default: false — always false in production)
# PDB_WEB_DEBUG=false
